msgstr ""
"ເມື່ອໃຊ້ຮູບແບບຊື່ interface ແບບ <prefix>.<vlan id>, <prefix> ບໍ່ສາມາດເປັນ 'vlan' ໄດ້."

#: ../pykickstart/commands/network.py:621
msgid "If network --interfacename contains a '.', valid vlan id should follow."
msgstr ""
"ຖ້າ network --interfacename ມີເຄື່ອງໝາຍ '.', ຕ້ອງມີ vlan id ທີ່ຖືກຕ້ອງຕາມຫຼັງ."

#: ../pykickstart/commands/network.py:630
msgid ""
"If network --interfacename starts with 'vlan', valid vlan id should follow."
msgstr ""
"ຖ້າ network --interfacename ເລີ່ມຕົ້ນດ້ວຍ 'vlan', ຕ້ອງມີ vlan id ທີ່ຖືກຕ້ອງຕາມຫຼັງ."

#: ../pykickstart/commands/network.py:635
#, python-format
msgid "The vlan id out of the %d-%d vlan id range."
msgstr "ຄ່າ vlan id ຢູ່ນອກໄລຍະ %d-%d."

