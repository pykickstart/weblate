#: ../pykickstart/base.py:187
#, python-format
msgid ""
"Ignoring deprecated command on line %(lineno)s:  The %(cmd)s command has "
"been deprecated and no longer has any effect.  It may be removed from future "
"releases, which will result in a fatal error from kickstart.  Please modify "
"your kickstart file to remove this command."
msgstr ""
"ກຳລັງລະເວັ້ນຄຳສັ່ງທີ່ຍົກເລີກແລ້ວໃນແຖວ %(lineno)s: ຄຳສັ່ງ %(cmd)s ຖືກຍົກເລີກແລ້ວ ແລະ ບໍ່ມີຜົນໃດໆອີ"
"ກ. ມັນອາດຈະຖືກລຶບອອກໃນເວີຊັນໜ້າ, ເຊິ່ງຈະເຮັດໃຫ້ເກີດຂໍ້ຜິດພາດຮ້າຍແຮງໃນ kickstart. ກະລຸນາແກ້ໄຂໄຟ"
"ລ໌ kickstart ຂອງທ່ານເພື່ອລຶບຄຳສັ່ງນີ້ອອກ."

#: ../pykickstart/base.py:418
#, python-format
msgid "Unknown command: %s"
msgstr "ບໍ່ຮູ້ຈັກຄຳສັ່ງ: %s"

#: ../pykickstart/parser.py:88
#, python-format
msgid "Illegal url for %%ksappend: %s"
msgstr "URL ບໍ່ຖືກຕ້ອງສຳລັບ %%ksappend: %s"

#: ../pykickstart/parser.py:93
#, python-format
msgid "Unable to open %%ksappend file: %s"
msgstr "ບໍ່ສາມາດເປີດໄຟລ໌ %%ksappend ໄດ້: %s"

#: ../pykickstart/parser.py:99 ../pykickstart/parser.py:101
#, python-format
msgid "Unable to open %%ksappend file"
msgstr "ບໍ່ສາມາດເປີດໄຟລ໌ %%ksappend ໄດ້"

#: ../pykickstart/parser.py:134 ../pykickstart/parser.py:762
#, python-format
msgid "Unable to open input kickstart file: %s"
msgstr "ບໍ່ສາມາດເປີດໄຟລ໌ນຳເຂົ້າ kickstart ໄດ້: %s"

#: ../pykickstart/parser.py:385
msgid "Group cannot specify both --nodefaults and --optional"
msgstr "ກຸ່ມບໍ່ສາມາດລະບຸທັງ --nodefaults ແລະ --optional ພ້ອມກັນໄດ້"

#: ../pykickstart/parser.py:566 ../pykickstart/parser.py:607
#, python-format
msgid "Section %s does not end with %%end."
msgstr "ສ່ວນ (section) %s ບໍ່ໄດ້ຈົບດ້ວຍ %%end."

#: ../pykickstart/parser.py:701
#, python-format
msgid "Unknown kickstart section: %s"
msgstr "ບໍ່ຮູ້ຈັກສ່ວນ (section) ຂອງ kickstart: %s"

#. If we are ignoring unknown section errors, just create a new
#. NullSection for the header we just saw.  Then nothing else
#. needs to change.  You can turn this warning into an error via
#. ksvalidator, or the warnings module.
#: ../pykickstart/parser.py:707
#, python-format
msgid "Potentially unknown section seen at line %(lineno)s: %(sectionName)s"
msgstr "ພົບສ່ວນ (section) ທີ່ອາດຈະບໍ່ຮູ້ຈັກໃນແຖວ %(lineno)s: %(sectionName)s"

#. If nothing else worked, we're out of options.
#: ../pykickstart/version.py:114 ../pykickstart/version.py:123
#: ../pykickstart/version.py:126 ../pykickstart/version.py:142
#: ../pykickstart/version.py:196
#, python-format
msgid "Unsupported version specified: %s"
msgstr "ເວີຊັນທີ່ລະບຸບໍ່ໄດ້ຮັບການຮອງຮັບ: %s"

#: ../pykickstart/options.py:82
#, python-format
msgid "Option %s is required"
msgstr "ຕົວເລືອກ %s ແມ່ນຈຳເປັນ"

#: ../pykickstart/options.py:86
#, python-format
msgid ""
"The %(option)s option was introduced in version %(intro)s, but you are using "
"kickstart syntax version %(version)s."
msgstr ""
"ຕົວເລືອກ %(option)s ຖືກນຳໃຊ້ຄັ້ງທຳອິດໃນເວີຊັນ %(intro)s, ແຕ່ທ່ານກຳລັງໃຊ້ syntax ຂອງ "
"kickstart ເວີຊັນ %(version)s."

#: ../pykickstart/options.py:92
#, python-format
msgid "The %(option)s option is no longer supported."
msgstr "ຕົວເລືອກ %(option)s ບໍ່ໄດ້ຮັບການຮອງຮັບອີກຕໍ່ໄປ."

#: ../pykickstart/options.py:94
#, python-format
msgid ""
"The %(option)s option was removed in version %(removed)s, but you are using "
"kickstart syntax version %(version)s."
msgstr ""
"ຕົວເລືອກ %(option)s ຖືກລຶບອອກໃນເວີຊັນ %(removed)s, ແຕ່ທ່ານກຳລັງໃຊ້ syntax ຂອງ "
"kickstart ເວີຊັນ %(version)s."

#: ../pykickstart/options.py:97
#, python-format
msgid ""
"Ignoring deprecated option on line %(lineno)s:  The %(option)s option has "
"been deprecated and no longer has any effect.  It may be removed from future "
"releases, which will result in a fatal error from kickstart.  Please modify "
"your kickstart file to remove this option."
msgstr ""
"ກຳລັງລະເວັ້ນຕົວເລືອກທີ່ຍົກເລີກແລ້ວໃນແຖວ %(lineno)s: ຕົວເລືອກ %(option)s ຖືກຍົກເລີກແລ້ວ ແລະ ບໍ່ມີ"
"ຜົນໃດໆອີກ. ມັນອາດຈະຖືກລຶບອອກໃນເວີຊັນໜ້າ, ເຊິ່ງຈະເຮັດໃຫ້ເກີດຂໍ້ຜິດພາດຮ້າຍແຮງໃນ kickstart. ກະລຸນາ"
"ແກ້ໄຂໄຟລ໌ kickstart ຂອງທ່ານເພື່ອລຶບຕົວເລືອກນີ້ອອກ."

#: ../pykickstart/options.py:136
#, python-format
msgid "Option %(opt)s: invalid boolean value: %(value)r"
msgstr "ຕົວເລືອກ %(opt)s: ຄ່າ boolean ບໍ່ຖືກຕ້ອງ: %(value)r"

#: ../pykickstart/options.py:141
#, python-format
msgid "Option %(opt)s: invalid string value: %(value)r"
msgstr "ຕົວເລືອກ %(opt)s: ຄ່າ string ບໍ່ຖືກຕ້ອງ: %(value)r"

#: ../pykickstart/options.py:178
msgid "Required flag set for option that doesn't take a value"
msgstr "ມີການຕັ້ງຄ່າ flag ທີ່ຈຳເປັນສຳລັບຕົວເລືອກທີ່ບໍ່ຮັບຄ່າ"

#: ../pykickstart/sections.py:270
msgid "--default and --nobase cannot be used together"
msgstr "--default ແລະ --nobase ບໍ່ສາມາດໃຊ້ຮ່ວມກັນໄດ້"

#: ../pykickstart/sections.py:272
msgid "--default and --nocore cannot be used together"
msgstr "--default ແລະ --nocore ບໍ່ສາມາດໃຊ້ຮ່ວມກັນໄດ້"

#: ../pykickstart/errors.py:46
#, python-format
msgid ""
"The following problem occurred on line %(lineno)s of the kickstart file:\n"
"\n"
"%(msg)s\n"
msgstr ""
"ເກີດບັນຫາຕໍ່ໄປນີ້ໃນແຖວ %(lineno)s ຂອງໄຟລ໌ kickstart:\n"
"\n"
"%(msg)s\n"

#: ../pykickstart/errors.py:48
#, python-format
msgid "There was a problem reading from line %s of the kickstart file"
msgstr "ເກີດບັນຫາໃນການອ່ານຈາກແຖວ %s ຂອງໄຟລ໌ kickstart"

#: ../pykickstart/commands/snapshot.py:101
msgid "Snapshot origin must be specified!"
msgstr "ຕ້ອງລະບຸຕົ້ນສະບັບຂອງ Snapshot!"

#: ../pykickstart/commands/snapshot.py:104
msgid "Snapshot origin can be specified only once!"
msgstr "ຕົ້ນສະບັບຂອງ Snapshot ສາມາດລະບຸໄດ້ພຽງຄັ້ງດຽວເທົ່ານັ້ນ!"

#: ../pykickstart/commands/snapshot.py:114
#, python-format
msgid "Snapshot with the name %s has been already defined!"
msgstr "Snapshot ທີ່ມີຊື່ %s ໄດ້ຖືກກຳນົດໄວ້ແລ້ວ!"

#: ../pykickstart/commands/snapshot.py:118
msgid "Snapshot \"when\" parameter must be specified!"
msgstr "ຕ້ອງລະບຸພາຣາມິເຕີ \"when\" ຂອງ Snapshot!"

#: ../pykickstart/commands/snapshot.py:123
#, python-format
msgid "Snapshot origin %s must be specified by VG/LV!"
msgstr "ຕົ້ນສະບັບ Snapshot %s ຕ້ອງລະບຸໂດຍ VG/LV!"

#: ../pykickstart/commands/snapshot.py:128
#, python-format
msgid "Snapshot when param must have one of these values %s!"
msgstr "ພາຣາມິເຕີ Snapshot when ຕ້ອງມີຄ່າໃດໜຶ່ງໃນ %s ນີ້!"

#: ../pykickstart/commands/repo.py:206 ../pykickstart/commands/firewall.py:118
#: ../pykickstart/commands/fcoe.py:116 ../pykickstart/commands/iscsi.py:145
#: ../pykickstart/commands/xconfig.py:99
#, python-format
msgid "Unexpected arguments to %(command)s command: %(options)s"
msgstr "ພົບຕົວກຳນົດທີ່ບໍ່ຄາດຄິດໃນຄຳສັ່ງ %(command)s: %(options)s"

#: ../pykickstart/commands/repo.py:211
msgid ""
"Only one of --baseurl and --mirrorlist may be specified for repo command."
msgstr ""
"ສາມາດລະບຸໄດ້ພຽງຢ່າງໃດຢ່າງໜຶ່ງລະຫວ່າງ --baseurl ແລະ --mirrorlist ສຳລັບຄຳສັ່ງ repo."

#: ../pykickstart/commands/repo.py:214
msgid "One of --baseurl or --mirrorlist must be specified for repo command."
msgstr "ຕ້ອງລະບຸ --baseurl ຫຼື --mirrorlist ຢ່າງໃດຢ່າງໜຶ່ງສຳລັບຄຳສັ່ງ repo."

#: ../pykickstart/commands/repo.py:222
#, python-format
msgid "A repo with the name %s has already been defined."
msgstr "ຄັງເກັບ (repo) ທີ່ມີຊື່ %s ໄດ້ຖືກກຳນົດໄວ້ແລ້ວ."

#: ../pykickstart/commands/repo.py:255
msgid "Method must be a url to be added to the repo list."
msgstr "ວິທີການ (Method) ຕ້ອງເປັນ URL ເພື່ອທີ່ຈະເພີ່ມເຂົ້າໃນລາຍຊື່ repo."

#: ../pykickstart/commands/cdrom.py:51 ../pykickstart/commands/skipx.py:51
#: ../pykickstart/commands/upgrade.py:57 ../pykickstart/commands/upgrade.py:94
#: ../pykickstart/commands/eula.py:64 ../pykickstart/commands/zerombr.py:67
#: ../pykickstart/commands/unsupported_hardware.py:52
#: ../pykickstart/commands/hmc.py:52 ../pykickstart/commands/autopart.py:46
#: ../pykickstart/commands/displaymode.py:60
#: ../pykickstart/commands/mediacheck.py:50
#: ../pykickstart/commands/interactive.py:51
#: ../pykickstart/commands/lilocheck.py:51
#, python-format
msgid "Kickstart command %s does not take any arguments"
msgstr "ຄຳສັ່ງ kickstart %s ບໍ່ຮອງຮັບຕົວກຳນົດໃດໆ"

#: ../pykickstart/commands/iscsiname.py:52 ../pykickstart/commands/key.py:60
#: ../pykickstart/commands/keyboard.py:52 ../pykickstart/commands/mouse.py:63
#: ../pykickstart/commands/lang.py:51
#, python-format
msgid "Kickstart command %s requires one argument"
msgstr "ຄຳສັ່ງ kickstart %s ຕ້ອງການໜຶ່ງຕົວກຳນົດ"

#: ../pykickstart/commands/harddrive.py:76
msgid "One of biospart or partition options must be specified."
msgstr "ຕ້ອງລະບຸຕົວເລືອກ biospart ຫຼື partition ຢ່າງໃດຢ່າງໜຶ່ງ."

#: ../pykickstart/commands/updates.py:54
#, python-format
msgid "Kickstart command %s only takes one argument"
msgstr "ຄຳສັ່ງ kickstart %s ຮອງຮັບພຽງແຕ່ຕົວກຳນົດດຽວເທົ່ານັ້ນ"

#: ../pykickstart/commands/ignoredisk.py:84
msgid "One of --drives or --only-use must be specified for ignoredisk command."
msgstr "ຕ້ອງລະບຸ --drives ຫຼື --only-use ຢ່າງໃດຢ່າງໜຶ່ງສຳລັບຄຳສັ່ງ ignoredisk."

#: ../pykickstart/commands/ignoredisk.py:139
msgid ""
"One of --drives , --only-use , or --interactive must be specified for "
"ignoredisk command."
msgstr ""
"ຕ້ອງລະບຸ --drives, --only-use, ຫຼື --interactive ຢ່າງໃດຢ່າງໜຶ່ງສຳລັບຄຳສັ່ງ ignoredisk."

#: ../pykickstart/commands/nvdimm.py:118
#, python-format
msgid "Unexpected arguments to nvdimm command: %(arguments)s"
msgstr "ພົບຕົວກຳນົດທີ່ບໍ່ຄາດຄິດໃນຄຳສັ່ງ nvdimm: %(arguments)s"

#: ../pykickstart/commands/nvdimm.py:122
msgid "Action argument is required for nvdimm command"
msgstr "ຕ້ອງການຕົວກຳນົດການກະທຳ (action argument) ສຳລັບຄຳສັ່ງ nvdimm"

#: ../pykickstart/commands/nvdimm.py:128
#, python-format
msgid "Invalid action argument (choose from '%(valid_arguments)s')"
msgstr "ຕົວກຳນົດການກະທຳບໍ່ຖືກຕ້ອງ (ເລືອກຈາກ '%(valid_arguments)s')"

#: ../pykickstart/commands/nvdimm.py:138
msgid ""
"Only one of --namespace and --blockdevs device specifications can be used"
msgstr ""
"ສາມາດໃຊ້ການລະບຸອຸປະກອນໄດ້ພຽງຢ່າງໃດຢ່າງໜຶ່ງລະຫວ່າງ --namespace ແລະ --blockdevs"

#: ../pykickstart/commands/nvdimm.py:144
#, python-format
msgid ""
"An action %(action)s on namespace %(namespace)s has already been defined."
msgstr "ການກະທຳ %(action)s ໃນ namespace %(namespace)s ໄດ້ຖືກກຳນົດໄວ້ແລ້ວ."

#: ../pykickstart/commands/nvdimm.py:147
#, python-format
msgid "An action %(action)s on devices %(blockdevs)s has already been defined."
msgstr "ການກະທຳ %(action)s ໃນອຸປະກອນ %(blockdevs)s ໄດ້ຖືກກຳນົດໄວ້ແລ້ວ."

#: ../pykickstart/commands/nvdimm.py:152
#, python-format
msgid "Action %(action)s requires --namespace argument to be set"
msgstr "ການກະທຳ %(action)s ຕ້ອງການໃຫ້ກຳນົດຕົວກຳນົດ --namespace"

#: ../pykickstart/commands/nvdimm.py:156
#, python-format
msgid ""
"Action %(action)s with mode %(mode)s requires --sectorsize argument to be set"
msgstr ""
"ການກະທຳ %(action)s ດ້ວຍໂໝດ %(mode)s ຕ້ອງການໃຫ້ກຳນົດຕົວກຳນົດ --sectorsize"

#: ../pykickstart/commands/nvdimm.py:161
#, python-format
msgid ""
"Action %(action)s requires --namespace or --blockdevs argument to be set"
msgstr "ການກະທຳ %(action)s ຕ້ອງການໃຫ້ກຳນົດຕົວກຳນົດ --namespace ຫຼື --blockdevs"

#: ../pykickstart/commands/sshkey.py:90 ../pykickstart/commands/keyboard.py:124
#: ../pykickstart/commands/rootpw.py:65 ../pykickstart/commands/rootpw.py:112
#: ../pykickstart/commands/timezone.py:63 ../pykickstart/commands/sshpw.py:128
#, python-format
msgid "A single argument is expected for the %s command"
msgstr "ຄາດຫວັງຕົວກຳນົດດຽວສຳລັບຄຳສັ່ງ %s"

#: ../pykickstart/commands/sshkey.py:94 ../pykickstart/commands/sshpw.py:133
#, python-format
msgid "An ssh user with the name %s has already been defined."
msgstr "ຜູ້ໃຊ້ ssh ທີ່ມີຊື່ %s ໄດ້ຖືກກຳນົດໄວ້ແລ້ວ."

#: ../pykickstart/commands/volgroup.py:133
msgid "volgroup must be given a VG name"
msgstr "volgroup ຕ້ອງໄດ້ຮັບຊື່ VG"

#: ../pykickstart/commands/volgroup.py:136
msgid "volgroup must be given a list of partitions"
msgstr "volgroup ຕ້ອງໄດ້ຮັບລາຍຊື່ຂອງພາທິຊັນ"

#: ../pykickstart/commands/volgroup.py:138
msgid "Members may not be specified for preexisting volgroup"
msgstr "ບໍ່ສາມາດລະບຸສະມາຊິກສຳລັບກຸ່ມວໍລຸມທີ່ມີຢູ່ແລ້ວໄດ້"

#: ../pykickstart/commands/volgroup.py:147
#, python-format
msgid "A volgroup with the name %s has already been defined."
