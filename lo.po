#: ../pykickstart/commands/device.py:144
#, python-format
msgid "%(command)s command requires a single argument: %(argument)s"
msgstr "ຄຳສັ່ງ %(command)s ຕ້ອງການພຽງແຕ່ຕົວກຳນົດດຽວ: %(argument)s"

#: ../pykickstart/commands/mount.py:187
msgid "'--mkfsoptions' requires --reformat"
msgstr "'--mkfsoptions' ຕ້ອງການ --reformat"

#: ../pykickstart/commands/network.py:834
#: ../pykickstart/commands/network.py:1060
#, python-format
msgid "--bindto=%s is not supported for this type of device"
msgstr "--bindto=%s ບໍ່ຮອງຮັບສຳລັບອຸປະກອນປະເພດນີ້"

#. pylint: disable=no-member
#: ../pykickstart/commands/bootloader.py:323
msgid "--boot-drive accepts only one argument"
msgstr "--boot-drive ຍອມຮັບພຽງແຕ່ຕົວກຳນົດດຽວເທົ່ານັ້ນ"

#: ../pykickstart/commands/logvol.py:637 ../pykickstart/commands/logvol.py:746
msgid "--chunksize and --metadatasize are for thin pools only"
msgstr "--chunksize ແລະ --metadatasize ແມ່ນໃຊ້ສຳລັບ thin pools ເທົ່ານັ້ນ"

#: ../pykickstart/sections.py:625
msgid "--default and --nobase cannot be used together"
msgstr "--default ແລະ --nobase ບໍ່ສາມາດໃຊ້ຮ່ວມກັນໄດ້"

#: ../pykickstart/sections.py:627
msgid "--default and --nocore cannot be used together"
msgstr "--default ແລະ --nocore ບໍ່ສາມາດໃຊ້ຮ່ວມກັນໄດ້"

#: ../pykickstart/commands/ignoredisk.py:172
msgid "--interactive option of ignoredisk command is no longer supported."
msgstr "ໂຕເລືອກ --interactive ຂອງຄຳສັ່ງ ignoredisk ແມ່ນບໍ່ຮອງຮັບອີກຕໍ່ໄປ."

#: ../pykickstart/commands/logvol.py:813 ../pykickstart/commands/logvol.py:870
#: ../pykickstart/commands/partition.py:685 ../pykickstart/commands/raid.py:725
msgid "--mkfsoptions and --fsprofile cannot be used together."
msgstr "--mkfsoptions ແລະ --fsprofile ບໍ່ສາມາດໃຊ້ຮ່ວມກັນໄດ້."

#: ../pykickstart/commands/logvol.py:810 ../pykickstart/commands/logvol.py:867
#: ../pykickstart/commands/partition.py:682 ../pykickstart/commands/raid.py:722
msgid "--mkfsoptions with --noformat has no effect."
msgstr "--mkfsoptions ທີ່ໃຊ້ຮ່ວມກັບ --noformat ຈະບໍ່ມີຜົນຫຍັງ."

#: ../pykickstart/commands/btrfs.py:264
msgid "--mkfsoptions with --noformat or --useexisting has no effect."
msgstr ""
"--mkfsoptions ທີ່ໃຊ້ຮ່ວມກັບ --noformat ຫຼື --useexisting ຈະບໍ່ມີຜົນຫຍັງ."

#: ../pykickstart/commands/partition.py:611
msgid "--resize can only be used in conjunction with --onpart"
msgstr "--resize ສາມາດໃຊ້ໄດ້ສະເພາະຮ່ວມກັບ --onpart ເທົ່ານັ້ນ"

#: ../pykickstart/commands/logvol.py:681
msgid "--resize can only be used in conjunction with --useexisting"
msgstr "--resize ສາມາດໃຊ້ໄດ້ສະເພາະຮ່ວມກັບ --useexisting ເທົ່ານັ້ນ"

#: ../pykickstart/commands/logvol.py:684
msgid "--resize requires --size to indicate new size"
msgstr "--resize ຕ້ອງການ --size ເພື່ອລະບຸຂະໜາດໃໝ່"

#: ../pykickstart/commands/partition.py:614
msgid "--resize requires --size to specify new size"
msgstr "--resize ຕ້ອງການ --size ເພື່ອລະບຸຂະໜາດໃໝ່"

#: ../pykickstart/commands/logvol.py:785
msgid "--size and --percent cannot both be specified for the same logvol"
msgstr "--size ແລະ --percent ບໍ່ສາມາດລະບຸທັງສອງຢ່າງໃຫ້ກັບ logvol ດຽວກັນໄດ້"

#: ../pykickstart/commands/logvol.py:627 ../pykickstart/commands/logvol.py:737
msgid "--thin and --thinpool cannot both be specified for the same logvol"
msgstr "--thin ແລະ --thinpool ບໍ່ສາມາດລະບຸທັງສອງຢ່າງໃຫ້ກັບ logvol ດຽວກັນໄດ້"

#: ../pykickstart/commands/logvol.py:632 ../pykickstart/commands/logvol.py:741
msgid "--thin requires --poolname to specify pool name"
msgstr "--thin ຕ້ອງການ --poolname ເພື່ອລະບຸຊື່ pool"

#: ../pykickstart/commands/dmraid.py:91
#, python-format
msgid ""
"A DM RAID device with the name %(name)s and devices %(devices)s has already "
"been defined."
msgstr ""
"ອຸປະກອນ DM RAID ທີ່ມີຊື່ %(name)s ແລະ ອຸປະກອນ %(devices)s ໄດ້ຖືກກຳນົດໄວ້ແລ້ວ."

#: ../pykickstart/commands/fcoe.py:143
#, python-format
msgid "A FCOE device with the name %s has already been defined."
msgstr "ອຸປະກອນ FCOE ທີ່ມີຊື່ %s ໄດ້ຖືກກຳນົດໄວ້ແລ້ວ."

#: ../pykickstart/commands/raid.py:458
#, python-format
msgid "A RAID device with the name %s has already been defined."
msgstr "ອຸປະກອນ RAID ທີ່ມີຊື່ %s ໄດ້ຖືກກຳນົດໄວ້ແລ້ວ."

#: ../pykickstart/commands/btrfs.py:233
#, python-format
msgid "A btrfs volume with the mountpoint %s has already been defined."
msgstr "ວໍລຸມ btrfs ທີ່ມີຈຸດຕິດຕັ້ງ %s ໄດ້ຖືກກຳນົດໄວ້ແລ້ວ."

#: ../pykickstart/commands/group.py:95
#, python-format
msgid "A group with the name %s has already been defined."
msgstr "ກຸ່ມທີ່ມີຊື່ %s ໄດ້ຖືກກຳນົດໄວ້ແລ້ວ."

#: ../pykickstart/commands/logvol.py:480
#, python-format
msgid ""
"A logical volume with the name %(logical_volume_name)s has already been "
"defined in volume group %(volume_group)s."
msgstr ""
"ວໍລຸມໂລຈິກທີ່ມີຊື່ %(logical_volume_name)s ໄດ້ຖືກກຳນົດໄວ້ແລ້ວໃນກຸ່ມວໍລຸມ %(volume_group)s."

#: ../pykickstart/commands/device.py:156
#, python-format
msgid "A module with the name %s has already been defined."
msgstr "ໂມດູນທີ່ມີຊື່ %s ໄດ້ຖືກກຳນົດໄວ້ແລ້ວ."

#: ../pykickstart/commands/network.py:478
#, python-format
msgid "A network device with the name %s has already been defined."
msgstr "ອຸປະກອນເຄືອຂ່າຍທີ່ມີຊື່ %s ໄດ້ຖືກກຳນົດໄວ້ແລ້ວ."

#: ../pykickstart/commands/partition.py:448
#, python-format
msgid "A partition with the mountpoint %s has already been defined."
msgstr "ພາທິຊັນທີ່ມີຈຸດຕິດຕັ້ງ %s ໄດ້ຖືກກຳນົດໄວ້ແລ້ວ."

#: ../pykickstart/commands/repo.py:291
#, python-format
msgid "A repo with the name %s has already been defined."
msgstr "ຄັງເກັບ (repo) ທີ່ມີຊື່ %s ໄດ້ຖືກກຳນົດໄວ້ແລ້ວ."

#: ../pykickstart/commands/keyboard.py:163 ../pykickstart/commands/rootpw.py:85
#: ../pykickstart/commands/rootpw.py:142 ../pykickstart/commands/sshpw.py:160
#, python-format
msgid "A single argument is expected for the %s command"
msgstr "ຄາດຫວັງຕົວກຳນົດດຽວສຳລັບຄຳສັ່ງ %s"

#: ../pykickstart/commands/user.py:202
#, python-format
msgid "A user with the name %s has already been defined."
msgstr "ຜູ້ໃຊ້ທີ່ມີຊື່ %s ໄດ້ຖືກກຳນົດໄວ້ແລ້ວ."

#: ../pykickstart/commands/volgroup.py:180
#, python-format
msgid "A volgroup with the name %s has already been defined."
msgstr "ກຸ່ມວໍລຸມ (volgroup) ທີ່ມີຊື່ %s ໄດ້ຖືກກຳນົດໄວ້ແລ້ວ."

#: ../pykickstart/commands/zfcp.py:132
msgid "A zfcp with this information has already been defined."
msgstr "zfcp ທີ່ມີຂໍ້ມູນນີ້ໄດ້ຖືກກຳນົດໄວ້ແລ້ວ."

#: ../pykickstart/commands/nvdimm.py:155
#, python-format
msgid "Action %(action)s requires --namespace argument to be set"
msgstr "ການກະທຳ %(action)s ຕ້ອງການໃຫ້ກຳນົດຕົວກຳນົດ --namespace"

#: ../pykickstart/commands/nvdimm.py:162
#, python-format
msgid ""
"Action %(action)s requires --namespace or --blockdevs argument to be set"
msgstr "ການກະທຳ %(action)s ຕ້ອງການໃຫ້ກຳນົດຕົວກຳນົດ --namespace ຫຼື --blockdevs"

#: ../pykickstart/commands/nvdimm.py:158
#, python-format
msgid ""
"Action %(action)s with mode %(mode)s requires --sectorsize argument to be set"
msgstr ""
"ການກະທຳ %(action)s ດ້ວຍໂໝດ %(mode)s ຕ້ອງການໃຫ້ກຳນົດຕົວກຳນົດ --sectorsize"

#: ../pykickstart/commands/logvol.py:847
msgid "Adding a cache to an existing logical volume is not supported"
msgstr "ບໍ່ຮອງຮັບການເພີ່ມ cache ໃສ່ວໍລຸມໂລຈິກທີ່ມີຢູ່ແລ້ວ"

#: ../pykickstart/commands/nvdimm.py:150
#, python-format
msgid "An action %(action)s on devices %(blockdevs)s has already been defined."
msgstr "ການກະທຳ %(action)s ໃນອຸປະກອນ %(blockdevs)s ໄດ້ຖືກກຳນົດໄວ້ແລ້ວ."

#: ../pykickstart/commands/nvdimm.py:147
#, python-format
msgid ""
"An action %(action)s on namespace %(namespace)s has already been defined."
msgstr "ການກະທຳ %(action)s ໃນ namespace %(namespace)s ໄດ້ຖືກກຳນົດໄວ້ແລ້ວ."

#: ../pykickstart/commands/sshkey.py:109 ../pykickstart/commands/sshpw.py:170
#, python-format
msgid "An ssh user with the name %s has already been defined."
msgstr "ຜູ້ໃຊ້ ssh ທີ່ມີຊື່ %s ໄດ້ຖືກກຳນົດໄວ້ແລ້ວ."

#: ../pykickstart/commands/timezone.py:266
#: ../pykickstart/commands/timezone.py:341
#, python-format
msgid "At least one option and/or an argument are expected for the  %s command"
msgstr "ຄາດຫວັງຢ່າງໜ້ອຍໜຶ່ງຕົວເລືອກ ແລະ/ຫຼື ຕົວກຳນົດ ສຳລັບຄຳສັ່ງ %s"

#: ../pykickstart/commands/network.py:752
#: ../pykickstart/commands/network.py:1055
msgid ""
"Bad format of --bridgeopts, expecting key=value options separated by ','"
msgstr ""
"ຮູບແບບຂອງ --bridgeopts ບໍ່ຖືກຕ້ອງ, ຕ້ອງເປັນຕົວເລືອກ key=value ທີ່ຂັ້ນດ້ວຍ ','"

#: ../pykickstart/commands/logvol.py:929
#: ../pykickstart/commands/partition.py:749 ../pykickstart/commands/raid.py:799
msgid "Btrfs file system is not supported"
msgstr "ບໍ່ຮອງຮັບລະບົບໄຟລ໌ Btrfs"

#: ../pykickstart/commands/logvol.py:855
msgid "Cache needs to have a list of (fast) PVs specified"
msgstr "Cache ຈຳເປັນຕ້ອງມີການລະບຸລາຍຊື່ຂອງ (fast) PVs"

#: ../pykickstart/commands/logvol.py:859
msgid "Cache needs to have size specified"
msgstr "Cache ຈຳເປັນຕ້ອງມີການລະບຸຂະໜາດ"

#: ../pykickstart/commands/logging.py:80
msgid "Can't specify --port without --host."
msgstr "ບໍ່ສາມາດລະບຸ --port ໂດຍບໍ່ມີ --host ໄດ້."

#: ../pykickstart/commands/multipath.py:98
#, python-format
msgid "Device '%(device)s' is already used in multipath '%(multipathdev)s'"
msgstr "ອຸປະກອນ '%(device)s' ຖືກໃຊ້ໃນ multipath '%(multipathdev)s' ແລ້ວ"

#: ../pykickstart/commands/rhsm.py:109
msgid "Empty string is not a valid activation key."
msgstr "ຂໍ້ຄວາມຫວ່າງເປົ່າບໍ່ແມ່ນລະຫັດເປີດໃຊ້ງານ (activation key) ທີ່ຖືກຕ້ອງ."

#. pylint: disable=no-member
#: ../pykickstart/load.py:81 ../pykickstart/load.py:84
#, python-format
msgid "Error accessing URL \"%s\""
msgstr "ເກີດຂໍ້ຜິດພາດໃນການເຂົ້າເຖິງ URL \"%s\""

#: ../pykickstart/load.py:109
#, python-format
msgid "Error copying file: %s"
msgstr "ເກີດຂໍ້ຜິດພາດໃນການຄັດລອກໄຟລ໌: %s"

#: ../pykickstart/load.py:99
#, python-format
msgid "Error opening file: %s"
msgstr "ເກີດຂໍ້ຜິດພາດໃນການເປີດໄຟລ໌: %s"

#: ../tools/ksvalidator.py:87
#, python-format
msgid ""
"Error reading %(filename)s:\n"
"%(version)s"
msgstr ""
"ເກີດຂໍ້ຜິດພາດໃນການອ່ານ %(filename)s:\n"
"%(version)s"

#: ../pykickstart/load.py:79
#, python-format
msgid "Error securely accessing URL \"%s\""
msgstr "ເກີດຂໍ້ຜິດພາດໃນການເຂົ້າເຖິງ URL \"%s\" ແບບປອດໄພ"

#: ../pykickstart/load.py:66
#, python-format
msgid "Error writing file \"%s\":"
msgstr "ເກີດຂໍ້ຜິດພາດໃນການຂຽນໄຟລ໌ \"%s\":"

#: ../tools/ksflatten.py:70
#, python-format
msgid "Failed to open output file '%(filename)s' : %(error_msg)s"
msgstr "ບໍ່ສາມາດເປີດໄຟລ໌ຜົນລັກສະນະ '%(filename)s' ໄດ້: %(error_msg)s"

#: ../tools/ksflatten.py:63
#, python-format
msgid "Failed to parse kickstart file '%(filename)s' : %(error_msg)s"
msgstr "ບໍ່ສາມາດວິເຄາະ (parse) ໄຟລ໌ kickstart '%(filename)s' ໄດ້: %(error_msg)s"

#: ../tools/ksflatten.py:60
#, python-format
msgid "Failed to read kickstart file '%(filename)s' : %(error_msg)s"
msgstr "ບໍ່ສາມາດອ່ານໄຟລ໌ kickstart '%(filename)s' ໄດ້: %(error_msg)s"

#: ../tools/ksvalidator.py:109
#, python-format
msgid ""
"File uses a deprecated option or command.\n"
"%s"
msgstr ""
"ໄຟລ໌ມີການໃຊ້ຕົວເລືອກ ຫຼື ຄຳສັ່ງທີ່ຖືກຍົກເລີກແລ້ວ.\n"
"%s"

#: ../tools/ksvalidator.py:117
#, python-format
msgid "General error in input file:  %s"
msgstr "ເກີດຂໍ້ຜິດພາດທົ່ວໄປໃນໄຟລ໌ນຳເຂົ້າ: %s"

#: ../tools/ksvalidator.py:114
msgid "General kickstart error in input file"
msgstr "ເກີດຂໍ້ຜິດພາດ kickstart ທົ່ວໄປໃນໄຟລ໌ນຳເຂົ້າ"

#: ../pykickstart/parser.py:439
msgid "Group cannot specify both --nodefaults and --optional"
msgstr "ກຸ່ມບໍ່ສາມາດລະບຸທັງ --nodefaults ແລະ --optional ພ້ອມກັນໄດ້"

#: ../pykickstart/commands/network.py:954
msgid "If network --interfacename contains a '.', valid vlan id should follow."
msgstr ""
"ຖ້າ network --interfacename ມີເຄື່ອງໝາຍ '.', ຕ້ອງມີ vlan id ທີ່ຖືກຕ້ອງຕາມຫຼັງ."

#: ../pykickstart/commands/network.py:963
msgid ""
"If network --interfacename starts with 'vlan', valid vlan id should follow."
msgstr ""
"ຖ້າ network --interfacename ເລີ່ມຕົ້ນດ້ວຍ 'vlan', ຕ້ອງມີ vlan id ທີ່ຖືກຕ້ອງຕາມຫຼັງ."

#: ../pykickstart/base.py:215
#, python-format
msgid ""
"Ignoring deprecated command on line %(lineno)s:  The %(cmd)s command has "
"been deprecated and no longer has any effect.  It may be removed from future "
"releases, which will result in a fatal error from kickstart.  Please modify "
"your kickstart file to remove this command."
msgstr ""
"ກຳລັງລະເວັ້ນຄຳສັ່ງທີ່ຍົກເລີກແລ້ວໃນແຖວ %(lineno)s: ຄຳສັ່ງ %(cmd)s ຖືກຍົກເລີກແລ້ວ ແລະ ບໍ່ມີຜົນໃດໆອີ"
"ກ. ມັນອາດຈະຖືກລຶບອອກໃນເວີຊັນໜ້າ, ເຊິ່ງຈະເຮັດໃຫ້ເກີດຂໍ້ຜິດພາດຮ້າຍແຮງໃນ kickstart. ກະລຸນາແກ້ໄຂໄຟ"
"ລ໌ kickstart ຂອງທ່ານເພື່ອລຶບຄຳສັ່ງນີ້ອອກ."

#: ../pykickstart/options.py:190
#, python-format
msgid ""
"Ignoring deprecated option on line %(lineno)s:  The %(option)s option has "
